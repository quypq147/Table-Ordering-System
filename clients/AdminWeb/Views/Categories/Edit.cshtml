@model AdminWeb.Dtos.RenameCategoryRequest
@{
    ViewData["Title"] = "Sửa danh mục";
    var id = (Guid)ViewBag.CategoryId;
    var displayOrder = ViewBag.DisplayOrder;
    var isActive = ViewBag.IsActive is bool b && b;
}

<h2>Sửa danh mục</h2>

<div class="mb-3">
    <div><strong>ID:</strong> @id</div>
    <div><strong>Thứ tự hiện tại:</strong> @displayOrder</div>
    <div><strong>Trạng thái:</strong> @(isActive ? "Active" : "Inactive")</div>
</div>

<form method="post" asp-action="Edit" asp-route-id="@id">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Tên danh mục</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit">Lưu</button>
        <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
    </div>
</form>

