@{
    ViewData["Title"] = "Tổng quan";
}

<div class="cards grid grid-cols-1 md:grid-cols-3 xl:grid-cols-6 gap-3">
    <div class="card"><div class="metric" data-metric="TotalTables">0</div><small>Tổng bàn</small></div>
    <div class="card"><div class="metric" data-metric="ActiveTables">0</div><small>Đang phục vụ</small></div>
    <div class="card"><div class="metric" data-metric="OrdersToday">0</div><small>Đơn hôm nay</small></div>
    <div class="card"><div class="metric" data-metric="OrdersInProgress">0</div><small>Đang chế biến</small></div>
    <div class="card"><div class="metric" data-metric="OrdersReady">0</div><small>Sẵn sàng phục vụ</small></div>
    <div class="card"><div class="metric" data-metric="RevenueToday">₫0</div><small>Doanh thu hôm nay</small></div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
    <div class="panel"><h4>Doanh thu theo giờ</h4><canvas id="revChart" height="140"></canvas></div>
    <div class="panel"><h4>Trạng thái đơn hôm nay</h4><canvas id="stationChart" height="140"></canvas></div>
</div>

<table class="table">
    <thead><tr><th>Mã</th><th>Trạng thái</th><th>Tổng</th><th>Lúc</th><th></th></tr></thead>
    <tbody id="recentOrders"></tbody>
</table>

<script id="dashboard-data" type="application/json">
    @Html.Raw(ViewBag.DashboardJson ?? "{}")
</script>

<!-- dashboard.js should read #dashboard-data and render charts/metrics -->
