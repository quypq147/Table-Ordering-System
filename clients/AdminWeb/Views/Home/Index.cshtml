@{
    ViewData["Title"] = "Dashboard";
}

<!-- JSON thực tế đẩy từ HomeController: ViewData["DashboardJson"] -->
<script id="dashboard-data" type="application/json">
@Html.Raw(ViewData["DashboardJson"] ?? "{}")
</script>

<section class="grid gap-lg">
    <div class="stats">
        <div class="stat kpi">
            <div class="stat-head">
                <span class="label">Tổng số bàn</span>
                <span class="stat-icon">🪑</span>
            </div>
            <div class="stat-value" data-metric="totalTables">0</div>
            <div class="muted">Đang hoạt động: <b data-metric="activeTables">0</b></div>
        </div>
        <div class="stat kpi">
            <div class="stat-head">
                <span class="label">Đang mở phiên</span>
                <span class="stat-icon">🔓</span>
            </div>
            <div class="stat-value" data-metric="openSessions">0</div>
            <div class="muted">Khách trung bình: <b data-metric="avgGuests">0</b></div>
        </div>
        <div class="stat kpi">
            <div class="stat-head">
                <span class="label">Tổng đơn hôm nay</span>
                <span class="stat-icon">🧾</span>
            </div>
            <div class="stat-value" data-metric="ordersToday">0</div>
            <div class="muted">Đơn có thể nhận: <b data-metric="ordersReady">0</b></div>
        </div>
        <div class="stat kpi">
            <div class="stat-head">
                <span class="label">Doanh thu hôm nay</span>
                <span class="stat-icon">₫</span>
            </div>
            <div class="stat-value" data-metric="revenueToday">0</div>
            <div class="muted">Trung bình mỗi vé: <b data-metric="avgTicket">0</b></div>
        </div>
        <div class="stat kpi">
            <div class="stat-head">
                <span class="label">KDS Ready</span>
                <span class="stat-icon">✅</span>
            </div>
            <div class="stat-value" data-metric="ticketsReady">0</div>
            <div class="muted">In Progress: <b data-metric="ticketsInProgress">0</b></div>
        </div>
        <div class="stat kpi">
            <div class="stat-head">
                <span class="label">Trung bình thời gian chuẩn bị</span>
                <span class="stat-icon">⏱️</span>
            </div>
            <div class="stat-value" data-metric="avgPrepMin">0m</div>
            <div class="muted">95th: <b data-metric="p95PrepMin">0m</b></div>
        </div>
    </div>

    <div class="cards-2col">
        <div class="card">
            <div class="card-head">
                <h3>Revenue (Today)</h3>
                <div class="seg">
                    <button class="seg-btn active">Hourly</button>
                </div>
            </div>
            <canvas id="revChart" height="110"></canvas>
        </div>
        <div class="card">
            <div class="card-head">
                <h3>KDS by Station</h3>
                <div class="seg">
                    <button class="seg-btn active">Live</button>
                </div>
            </div>
            <canvas id="stationChart" height="110"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-head between">
            <h3>Đơn gần đây</h3>
            <a class="ghost" asp-controller="Orders" asp-action="Index">View all</a>
        </div>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Tình trạng</th>
                        <th>Tổng tiền</th>
                        <th>Tạo vào</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="recentOrders">
                    <!-- JS render từ dashboard-data hoặc fallback demo -->
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-head between">
            <h3>Các chức năng </h3>
        </div>
        <div class="quick">
            <a class="ghost" asp-controller="Tables" asp-action="Index">Mở / Ghép / Chuyển Bàn</a>
            <a class="ghost" asp-controller="Menu" asp-action="Create">Tạo menu các món</a>
            <a class="ghost" asp-controller="Orders" asp-action="Index">Xem các đơn</a>
        </div>
    </div>
</section>
