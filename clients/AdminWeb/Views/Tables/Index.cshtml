@model List<AdminWeb.Dtos.DiningTableDto>
@{
    ViewData["Title"] = "Bàn ăn";
}

<section class="card">
    <div class="card-head between">
        <h3>Quản lý bàn</h3>
        <a class="ghost" asp-action="Create">+ Thêm bàn ăn</a>
    </div>

    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr><th>Mã bàn</th><th>Số ghế</th><th>Trạng thái</th></tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td>@t.Code</td>
                        <td>@t.Seats</td>
                        <td>
                            
               @(t.Status == 1 ? "Đang hoạt động" : "Không hoạt động")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>


