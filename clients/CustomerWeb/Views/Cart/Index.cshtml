@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var orderId = (Guid)ViewBag.OrderId;
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container py-3">
 <div class="d-flex justify-content-between align-items-center mb-3">
 <h3 class="mb-0">Giỏ hàng</h3>
 <div>
 <a id="backMenu" class="btn btn-outline-secondary btn-sm" href="#">Quay lại Menu</a>
 <button id="btnLeave" class="btn btn-outline-danger btn-sm ms-2">Rời bàn</button>
 </div>
 </div>

 <div class="mb-2 small text-muted" id="cartMeta"></div>

 <div class="table-responsive">
 <table class="table align-middle" id="cartTable">
 <thead>
 <tr>
 <th>Món</th>
 <th style="width:220px">Ghi chú</th>
 <th style="width:140px">Số lượng</th>
 <th style="width:140px" class="text-end">Đơn giá</th>
 <th style="width:160px" class="text-end">Thành tiền</th>
 <th style="width:120px"></th>
 </tr>
 </thead>
 <tbody id="cartBody">
 <tr><td colspan="6" class="text-muted">Đang tải...</td></tr>
 </tbody>
 <tfoot>
 <tr>
 <td colspan="3"></td>
 <td class="text-end">Tạm tính</td>
 <td class="text-end" id="subtotal">0</td>
 <td></td>
 </tr>
 <tr>
 <td colspan="3"></td>
 <td class="text-end">Phí phục vụ</td>
 <td class="text-end" id="svc">0</td>
 <td></td>
 </tr>
 <tr>
 <td colspan="3"></td>
 <td class="text-end">Thuế</td>
 <td class="text-end" id="tax">0</td>
 <td></td>
 </tr>
 <tr class="fw-bold">
 <td colspan="3"></td>
 <td class="text-end">Tổng cộng</td>
 <td class="text-end" id="total">0</td>
 <td></td>
 </tr>
 </tfoot>
 </table>
 </div>

 <div class="d-flex gap-2">
 <button id="btnClear" class="btn btn-outline-danger">Xóa hết</button>
 <button id="btnSubmit" class="btn btn-primary">Gửi đơn hàng</button>
 </div>
</div>

<!-- Toast -->
<div class="position-fixed top-0 start-50 translate-middle-x p-3" style="z-index:1080">
 <div id="toast" class="toast align-items-center text-bg-danger border-0">
 <div class="d-flex">
 <div class="toast-body" id="toastMsg">Đã có lỗi</div>
 <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
 </div>
 </div>
</div>

@section Scripts {
 <script>
 const orderId = "@orderId";
 let cart = null;
 let statusTimer = null;

 const statusMap = {
 Draft: 'Đang chọn món',
 Submitted: 'Đã gửi bếp',
 InProgress: 'Đang chế biến',
 Ready: 'Món đã sẵn sàng',
 Served: 'Đã phục vụ',
 Cancelled: 'Đã hủy'
 };

 function fmt(x){ return (x||0).toLocaleString() + ' ₫'; }
 function toast(msg, ok=false){
 const el = document.getElementById("toast");
 el.classList.toggle("text-bg-success", ok);
 el.classList.toggle("text-bg-danger", !ok);
 document.getElementById("toastMsg").textContent = msg || (ok ? "Thành công" : "Đã có lỗi");
 bootstrap.Toast.getOrCreateInstance(el).show();
 }
 async function api(url, opt = {}) {
 const r = await fetch(url, { headers: { "Content-Type": "application/json" }, ...opt });
 const raw = await r.text();
 let data = raw; try { data = raw ? JSON.parse(raw) : null; } catch {}
 if (!r.ok){ const msg = (data && typeof data === 'object' && (data.title || data.detail || data.message)) || raw || r.statusText; throw new Error(msg); }
 return data;
 }
 function renderMeta(){
 const statusText = statusMap[cart?.status] ?? cart?.status ?? '';
 document.getElementById('cartMeta').textContent = cart?.tableCode ? `Bàn ${cart.tableCode} · Trạng thái: ${statusText}` : 'Giỏ hàng';
 }
 function updateBackLink(){
 const backHref = cart?.tableCode ? `/client/menu?tableCode=${encodeURIComponent(cart.tableCode)}` : '#';
 const back = document.getElementById('backMenu');
 back.href = backHref;
 back.classList.toggle('disabled', backHref === '#');
 }
 async function load(showErrorToast = true){
 const prevTable = cart && cart.tableCode ? cart.tableCode : null;
 try{
 const data = await api(`/proxy/public/cart/${orderId}`);
 cart = (data && typeof data === 'object') ? data : { items: [] };
 }catch(e){
 cart = { items: [] };
 if (showErrorToast) toast(e.message);
 }
 if(!cart.tableCode && prevTable) cart.tableCode = prevTable;
 const items = Array.isArray(cart.items) ? cart.items : [];
 renderMeta();
 document.getElementById('subtotal').textContent = fmt(cart.subtotal ||0);
 document.getElementById('svc').textContent = fmt(cart.serviceCharge ||0);
 document.getElementById('tax').textContent = fmt(cart.tax ||0);
 document.getElementById('total').textContent = fmt(cart.total ||0);
 updateBackLink();
 renderItems(items);
 const hasItems = items.length >0;
 document.getElementById('btnSubmit').disabled = !hasItems || cart.status !== 'Draft';
 document.getElementById('btnClear').disabled = !hasItems || cart.status !== 'Draft';
 document.getElementById('btnLeave').disabled = !orderId;
 }
 function renderItems(items){
 const body = document.getElementById('cartBody');
 if(!items.length){ body.innerHTML = '<tr><td colspan="6" class="text-muted">Giỏ hàng đang trống.</td></tr>'; return; }
 body.innerHTML = items.map(it => `
 <tr data-id="${it.id}" data-menu-id="${it.menuItemId}" data-order-item-id="${it.orderItemId||0}">
 <td><div class="fw-semibold">${it.name || ''}</div></td>
 <td><textarea class="form-control form-control-sm note" rows="1" ${cart?.status !== 'Draft' ? 'disabled' : ''}>${it.note || ''}</textarea></td>
 <td>
 <div class="input-group input-group-sm">
 <button class="btn btn-outline-secondary btn-dec" type="button" ${cart?.status !== 'Draft' ? 'disabled' : ''}>-</button>
 <input type="number" class="form-control text-center qty" min="1" value="${it.quantity ||1}" ${cart?.status !== 'Draft' ? 'disabled' : ''}>
 <button class="btn btn-outline-secondary btn-inc" type="button" ${cart?.status !== 'Draft' ? 'disabled' : ''}>+</button>
 </div>
 </td>
 <td class="text-end">${fmt(it.unitPrice)}</td>
 <td class="text-end line-total">${fmt(it.lineTotal)}</td>
 <td class="text-end">
 <div class="btn-group btn-group-sm">
 <button class="btn btn-outline-primary btn-save" ${cart?.status !== 'Draft' ? 'disabled' : ''}>Cập nhật</button>
 <button class="btn btn-outline-danger btn-del" ${cart?.status !== 'Draft' ? 'disabled' : ''}>Xóa</button>
 </div>
 </td>
 </tr>`).join('');

 if(cart?.status === 'Draft'){
 body.querySelectorAll('tr[data-id]').forEach(tr =>{
 const qtyEl = tr.querySelector('.qty');
 const noteEl = tr.querySelector('.note');
 tr.querySelector('.btn-inc').onclick = ()=>{ qtyEl.value = Math.max(1, parseInt(qtyEl.value||'1',10)+1); save(tr, qtyEl.value, noteEl.value); };
 tr.querySelector('.btn-dec').onclick = ()=>{ qtyEl.value = Math.max(1, parseInt(qtyEl.value||'1',10)-1); save(tr, qtyEl.value, noteEl.value); };
 tr.querySelector('.btn-save').onclick = ()=> save(tr, qtyEl.value, noteEl.value);
 tr.querySelector('.btn-del').onclick = ()=> removeItem(tr.getAttribute('data-menu-id'));
 });
 }
 }
 async function save(rowEl, qty, note){
 try{
 qty = Math.max(1, parseInt(qty||'1',10));
 const orderItemId = parseInt(rowEl.getAttribute('data-order-item-id')||'0',10);
 if(!orderItemId){ throw new Error('Thiếu orderItemId'); }
 // Patch quantity then note to match backend
 await api(`/proxy/public/cart/${orderId}/items/${orderItemId}`, { method:'PATCH', body: JSON.stringify({ quantity: qty })});
 await api(`/proxy/public/cart/${orderId}/items/${orderItemId}/note`, { method:'PATCH', body: JSON.stringify({ note: note || null })});
 await load(false);
 toast('Đã cập nhật', true);
 }catch(e){ toast(e.message); }
 }
 async function removeItem(menuItemId){
 if(!confirm('Xóa món này khỏi giỏ?')) return;
 try{
 await api(`/proxy/public/cart/${orderId}/items`, { method:'DELETE', body: JSON.stringify({ menuItemId }) });
 // Cập nhật ngay giao diện để không hiển thị món đã xóa
 cart.items = (cart.items || []).filter(x => x.menuItemId !== menuItemId);
 renderItems(cart.items);
 // Đồng bộ lại từ server (không hiện toast lỗi nếu trễ)
 setTimeout(()=> load(false),200);
 toast('Đã xóa', true);
 }catch(e){ toast(e.message); }
 }
 async function clearAll(){
 if(!confirm('Xóa tất cả món trong giỏ?')) return;
 try{
 await api(`/proxy/public/cart/${orderId}/clear`, { method:'POST' });
 if(statusTimer) { clearInterval(statusTimer); statusTimer = null; }
 // Xóa local thay vì chờ load trả về
 cart.items = [];
 renderItems(cart.items);
 document.getElementById('subtotal').textContent = fmt(0);
 document.getElementById('svc').textContent = fmt(0);
 document.getElementById('tax').textContent = fmt(0);
 document.getElementById('total').textContent = fmt(0);
 document.getElementById('btnSubmit').disabled = true;
 document.getElementById('btnClear').disabled = true;
 // Tải lại sau một chút để đồng bộ trạng thái khác (nếu có)
 setTimeout(()=> load(false),300);
 toast('Đã xóa hết', true);
 }catch(e){ toast(e.message); }
 }
 async function submit(){
 const items = (cart && Array.isArray(cart.items)) ? cart.items : [];
 if(items.length ===0) { toast('Giỏ hàng đang trống'); return; }
 if(cart.status !== 'Draft'){ toast('Đơn hàng đã được gửi / không thể gửi lại'); return; }
 if(!confirm('Gửi đơn hàng tới bếp?')) return;
 try{
 await api(`/proxy/public/cart/${orderId}/submit`, { method:'POST', body: '{}' });
 toast('Đã gửi đơn hàng!', true);
 document.getElementById('btnSubmit').disabled = true;
 document.getElementById('btnClear').disabled = true;
 if(statusTimer) clearInterval(statusTimer);
 statusTimer = setInterval(()=> load(false),5000);
 }catch(e){ toast(e.message); }
 }
 async function leaveTable(){
 if(!orderId) return;
 if(!confirm('Kết thúc phiên và xoá giỏ hàng (nếu chưa gửi)?')) return;
 try{
 await api(`/proxy/public/cart/${orderId}/close-session`, { method:'POST', body:'{}' });
 toast('Đã rời bàn', true);
 setTimeout(()=> window.location.href='/client/qr-help',800);
 }catch(e){ toast(e.message); }
 }
 // Xử lý click quay lại menu ngay cả khi href '#' (chưa load xong)
 document.getElementById('backMenu').addEventListener('click', (e)=>{
 const href = e.currentTarget.getAttribute('href');
 if(href === '#'){
 e.preventDefault();
 if(!cart) { load(false); return; }
 if(cart.tableCode){ window.location.href = `/client/menu?tableCode=${encodeURIComponent(cart.tableCode)}`; }
 }
 });
 window.addEventListener('beforeunload', () => {
 try {
 if(orderId){
 const data = new Blob([], { type: 'application/json' });
 navigator.sendBeacon(`/proxy/public/cart/${orderId}/close-session`, data);
 }
 } catch { }
 });
 document.getElementById('btnLeave').addEventListener('click', leaveTable);
 document.getElementById('btnClear').addEventListener('click', clearAll);
 document.getElementById('btnSubmit').addEventListener('click', submit);
 (async()=>{ try{ await load(); } catch(e){ toast(e.message); } })();
 </script>
}
